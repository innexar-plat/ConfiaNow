    "@platform/communication": "0.1.0",
    "@platform/config": "0.1.0",
    "@platform/database": "0.1.0",
    "@platform/discovery": "0.1.0",
    "@platform/evidence": "0.1.0",
    "@platform/integrations": "0.1.0",
    "@platform/leads": "0.1.0",
    "@platform/moderation": "0.1.0",
    "@platform/notifications": "0.1.0",
    "@platform/profiles": "0.1.0",
